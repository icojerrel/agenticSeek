# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN='your_bot_token_here'

# Your personal Chat ID (use /start in bot then check logs)
TELEGRAM_CHAT_ID='your_chat_id_here'

# Telegram Mode: 'polling' (default) or 'webhook'
TELEGRAM_MODE='polling'

# Webhook URL (only needed for webhook mode)
TELEGRAM_WEBHOOK_URL='https://your-domain.com/telegram/webhook'

# AgenticSeek Configuration
SEARXNG_BASE_URL="http://searxng:8080"
REDIS_BASE_URL="redis://redis:6379/0"
WORK_DIR="/path/to/your/workspace"
OLLAMA_PORT="11434"
LM_STUDIO_PORT="1234"
CUSTOM_ADDITIONAL_LLM_PORT="11435"

# Optional API Keys (leave empty for local-only use)
OPENAI_API_KEY='optional'
DEEPSEEK_API_KEY='optional'
OPENROUTER_API_KEY='optional'
TOGETHER_API_KEY='optional'
GOOGLE_API_KEY='optional'
ANTHROPIC_API_KEY='optional'
HUGGINGFACE_API_KEY='optional'
DSK_DEEPSEEK_API_KEY='optional'
